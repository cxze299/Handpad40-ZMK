CONFIG_SOC_SERIES_NRF52X=y
CONFIG_SOC_NRF52840_QIAA=y
CONFIG_BOARD_E73_HANDPAD40_UF2=y

CONFIG_ARM_MPU=y
CONFIG_GPIO=y
CONFIG_USE_DT_CODE_PARTITION=y

# This board uses an Adafruit/Nordic pca10056 UF2 bootloader with S140.
# The application must live after the bootloader + SoftDevice region.
CONFIG_BUILD_OUTPUT_UF2=y
CONFIG_BUILD_OUTPUT_UF2_FAMILY_ID="0x239A0029"

# E73 exposes XL1/XL2 pins, and this keyboard uses P0.26 as COL1.
# Use the internal RC LFCLK instead of reserving XL1/XL2 for a 32.768 kHz crystal.
CONFIG_CLOCK_CONTROL_NRF_K32SRC_RC=y
CONFIG_CLOCK_CONTROL_NRF_K32SRC_500PPM=y

CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y

CONFIG_ZMK_USB=y
